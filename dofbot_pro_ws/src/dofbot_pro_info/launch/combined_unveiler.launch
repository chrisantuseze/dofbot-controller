<?xml version="1.0"?>
<launch>
  <!--
    Combined Jetson launch for the Unveiler stack.

    Usage (on Jetson):
      cd ~/echris/object-unveiler/dofbot_pro_ws
      source devel/setup.bash
      roslaunch dofbot_pro_info combined_unveiler.launch

    Notes:
    - This file assumes the `rosbridge_server` and `orbbec_camera` packages
      are installed on the Jetson and available in the ROS_PACKAGE_PATH.
    - Keep this lightweight: if any node must run in a separate machine or
      container, remove it from the launch and run it manually.
  -->

  <!-- Start rosbridge websocket (includes ws server on port 9090) -->
  <include file="$(find rosbridge_server)/launch/rosbridge_websocket.launch" />

  <!-- Start the camera driver (Orbbec dabai) -->
  <include file="$(find orbbec_camera)/launch/dabai_dcw2.launch" />

  <!-- IK / kinematics service -->
  <node pkg="dofbot_pro_info" type="kinemarics_dofbot" name="kinemarics_dofbot" output="screen" />

  <!-- Arm driver (publishes TargetAngle) -->
  <node pkg="dofbot_pro_info" type="arm_driver.py" name="arm_driver" output="screen" />

  <!-- Robot controller (waits for lab inference server) -->
  <node pkg="dofbot_pro_info" type="unveiler_grasp.py" name="unveiler_grasp" output="screen" />

</launch>
